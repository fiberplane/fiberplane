---
import {
  ApiReference as ApiRef,
  type ReferenceConfiguration,
} from "@scalar/api-reference";

interface Props {
  configuration: ReferenceConfiguration;
}

const ApiReferenceProps = Astro.props;

const { configuration } = ApiReferenceProps;

const { spec } = configuration;

if (!spec?.url && !spec?.content && !spec?.preparsedContent) {
  throw new Error(
    "[APIReference] You didn’t provide a spec.content or spec.url. Please provide one of these options.",
  );
}
---

<ApiRef {configuration} client:only="vue" />
