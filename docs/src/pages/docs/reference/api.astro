---
import ApiReference from "@components/ApiReference.astro"
import type { Props } from '@astrojs/starlight/props';
import Header from "@components/Header.astro"
import { parseSwaggerFile } from "@scalar/swagger-parser"

import type { ReferenceConfiguration } from "@scalar/api-reference";
const openApiSpecPath = "https://raw.githubusercontent.com/fiberplane/fiberplane/main/schemas/openapi_v1.yml"

import fs from "node:fs/promises" 

const path = new URL("../../../../../schemas/openapi_v1.yml", import.meta.url).pathname
const openApi = await fs.readFile(path, "utf-8")

const configuration: ReferenceConfiguration = {
	spec: {
		// url: openApiSpecPath
		content: openApi
	},
	searchHotKey: "p",
	layout: "modern",
	darkMode: false,

};

